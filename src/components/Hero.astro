---
import LinkedIn from "@/components/icons/LinkedIn.astro"
import GitHub from "@/components/icons/GitHub.astro"
import Mail from "@/components/icons/Mail.astro"
---

<section class="relative w-full min-h-[90vh] flex items-end pb-20 md:pb-32 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/akshat.png"
      alt=""
      class="w-full h-full object-cover object-top opacity-30 dark:opacity-20 scale-110 blur-sm"
    />
  </div>

  <!-- Gradient overlays -->
  <div class="absolute inset-0 z-[1] bg-gradient-to-r from-white via-white/80 to-transparent dark:from-netflix-dark dark:via-netflix-dark/80 dark:to-transparent"></div>
  <div class="absolute inset-0 z-[1] bg-gradient-to-t from-white via-transparent to-white/50 dark:from-netflix-dark dark:via-transparent dark:to-netflix-dark/50"></div>

  <!-- Content -->
  <div class="relative z-10 px-6 md:px-12 max-w-[1400px] mx-auto w-full">
    <div class="max-w-2xl">
      <span class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-wider uppercase bg-netflix-red text-white rounded">
        Computer Science @ USC
      </span>

      <h1 class="font-display text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-wide text-gray-900 dark:text-white leading-none mb-4">
        AKSHAT<br/>SHAH
      </h1>

      <p class="text-base md:text-lg text-gray-700 dark:text-netflix-light-gray max-w-lg mb-8 leading-relaxed">
        Aspiring <strong class="text-netflix-red font-semibold">Software Engineer</strong> crafting scalable solutions with React, Node.js, and Django.
        Passionate about data-driven problem solving and building user-centric applications.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-3 mb-6">
        <a
          href="https://drive.google.com/file/d/1U9WqGSLeUFIHTWGOlY-hno-8sHDwdJ5i/view"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-6 py-2.5 bg-white dark:bg-white text-gray-900 font-semibold rounded text-sm hover:bg-gray-200 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          View Resume
        </a>
        <a
          href="mailto:akshatshahh2003@gmail.com"
          class="flex items-center gap-2 px-6 py-2.5 bg-gray-500/30 dark:bg-gray-500/30 text-gray-900 dark:text-white font-semibold rounded text-sm hover:bg-gray-500/50 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          Contact Me
        </a>
      </div>

      <!-- Social links -->
      <div class="flex gap-4">
        <a href="https://linkedin.com/in/akshatshahh" target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-netflix-light-gray hover:text-netflix-red transition-colors">
          <LinkedIn class="size-5" />
        </a>
        <a href="https://github.com/akshatshahh" target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-netflix-light-gray hover:text-netflix-red transition-colors">
          <GitHub class="size-5" />
        </a>
        <a href="mailto:akshatshahh2003@gmail.com" class="text-gray-500 dark:text-netflix-light-gray hover:text-netflix-red transition-colors">
          <Mail class="size-5" />
        </a>
      </div>
    </div>
  </div>
</section>
